# ── Landing (Netlify) ──────────────────────────────────
PUBLIC_WEB_URL=http://localhost:5173

# ── Web (Vercel) ───────────────────────────────────────
VITE_API_URL=http://localhost:3000

# ── Stats / Cassa (Supabase diretto) ───────────────────
# Legge DIRETTAMENTE da Supabase (serverless), senza backend.
# La publishable key è sicura lato browser: la tabella ha RLS (sola lettura anon).
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ── API / Cucina (Render / Railway) ────────────────────
WEB_ORIGIN=http://localhost:5173
ENGINE_URL=http://localhost:8000
PORT=3000
# Connection string Supabase. Runtime: transaction pooler (porta 6543).
# Il push dello schema (drizzle-kit) usa la session mode (5432) in automatico.
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ── Engine / Macinino (Vercel — Python serverless) ─────
MOONSHOT_API_KEY=
PORT=8000
